# =============================================================================
# ReasonGenPilot config template
# Copy to config/.env and fill in your keys:
#   cp config/.env.example config/.env
# =============================================================================

# --- MLLM: text + vision ---
# Used by: gen (prompt optimize, VQA), edit (Reason Agent, VQA)
# Must support OpenAI-compatible /chat/completions with image_url.
# 启用下方 ONE 组 MLLM_*，另一组整段注释掉即可切换。
#
# 共用参数（两组通用）：
MLLM_TIMEOUT=60
MLLM_VISION_TIMEOUT=120
MLLM_VISION_MAX_SIDE=1024
MLLM_VISION_DETAIL=auto
MLLM_APP_NAME=ReasonGenPilot
MLLM_HTTP_REFERER=

# [推荐] DashScope Qwen-VL（可与 T2I 同 API Key）
# MLLM_API_KEY=your_dashscope_key_here
# MLLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MLLM_MODEL=qwen-vl-plus

# [备选] OpenRouter 免费 vision
# MLLM_API_KEY=your_openrouter_key_here
# MLLM_BASE_URL=https://openrouter.ai/api/v1
# MLLM_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# --- T2I: gen route text-to-image ---
# Backends: dry_run | dashscope | siliconflow | comfyui
T2I_BACKEND=dashscope
T2I_API_KEY=your_dashscope_key_here
T2I_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
T2I_MODEL=qwen-image-2.0

# --- EDIT: edit route instruction editing (no mask) ---
# Backends: dry_run | dashscope
# dashscope uses the same multimodal-generation API: input image + edit_prompt text.
# You may set EDIT_* equal to T2I_* or leave EDIT_API_KEY empty to auto-fallback.
EDIT_BACKEND=dashscope
EDIT_API_KEY=your_dashscope_key_here
EDIT_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# qwen-image-2.0-pro 画质更好；qwen-image-2.0 更快
EDIT_MODEL=qwen-image-2.0-pro
# 长 prompt 建议关闭改写，减少整图重绘与噪点
EDIT_PROMPT_EXTEND=false
# 留空则自动匹配输入图分辨率；也可手动指定如 1536*1024
EDIT_SIZE=
EDIT_NEGATIVE_PROMPT=noise, grain, blur, low quality, artifacts, oversharpened

# --- Optional: local ComfyUI (future inpaint / FLUX workflow) ---
COMFYUI_URL=http://127.0.0.1:8188
