MLLM_API_KEY=your_mllm_key_here
MLLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MLLM_MODEL=gemini-2.0-flash
MLLM_TIMEOUT=60

# Optional generation backends.
# t2i_client.py currently supports:
#   dry_run: no network, writes a placeholder SVG for pipeline testing.
#   siliconflow: OpenAI-like /images/generations endpoint.
#   dashscope: DashScope native Qwen-Image endpoint.
#   comfyui: placeholder adapter boundary for the local ComfyUI workflow used later.
T2I_BACKEND=dry_run
T2I_API_KEY=your_t2i_key_here
T2I_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
T2I_MODEL=qwen-image-2.0
COMFYUI_URL=http://127.0.0.1:8188
